{
  "name": "snipforge-vscode",
  "displayName": "SnipForge - Code Snippets",
  "description": "Save and retrieve code snippets directly from VS Code",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "publisher": "swayamdev05",
  "repository": {
    "type": "git",
    "url": "https://github.com/swayamyadav05/snipforge.git",
    "directory": "apps/vscode-ext"
  },
  "homepage": "https://github.com/swayamyadav05/snipforge#readme",
  "bugs": {
    "url": "https://github.com/swayamyadav05/snipforge/issues"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "snipforge.saveSelection",
        "title": "SnipForge: Save Selection"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@devsnap/typescript-config": "*",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.24.0",
    "typescript": "5.9.2"
  }
}
